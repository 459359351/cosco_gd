# ---- 数据库密码 ----
DB_PASSWORD=postgres

# ---- 前端对外端口 ----
FRONTEND_PORT=3080

# ---- 高德地图配置（前端构建时注入）----
# 获取地址：https://console.amap.com/dev/key/app
VITE_AMAP_KEY=6278e1f752ad273e4a09ce52513e5aca
VITE_AMAP_SECURITY=94311fde77e8ab9d46fbe1346434874b

# ---- API 请求前缀 ----
# 通过 nginx 反向代理到后端，一般不需要修改
VITE_API_BASE=/api/v1
