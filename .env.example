# ==============================================
# COSCO GD 集装箱修理驾驶舱 — Docker 部署配置
# 复制为 .env 后按需修改：cp .env.example .env
# ==============================================

# ---- 数据库密码 ----
DB_PASSWORD=postgres

# ---- 前端对外端口 ----
FRONTEND_PORT=3000

# ---- 高德地图配置（前端构建时注入，必填）----
# 获取地址：https://console.amap.com/dev/key/app
VITE_AMAP_KEY=
VITE_AMAP_SECURITY=

# ---- API 请求前缀 ----
VITE_API_BASE=/api/v1
